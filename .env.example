# Copy to .env and adjust before running: cp .env.example .env
#
# Used by docker compose for both compose interpolation and container env.
# For local (non-Docker) runs, the same variables are read by src/config.js.

# ─── Docker Compose ───────────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=freeqwenapi
CONTAINER_NAME=qwen-proxy
IMAGE_NAME=qwen-api-proxy
IMAGE_TAG=latest
HOST_PORT=3264
RESTART_POLICY=unless-stopped
SHM_SIZE=1gb

# Host paths mounted into the container
SESSION_VOLUME=./session
LOGS_VOLUME=./logs
UPLOADS_VOLUME=./uploads

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3264
HOST=0.0.0.0
NODE_ENV=production
SKIP_ACCOUNT_MENU=true
DEFAULT_MODEL=qwen-max-latest
ALLOW_UNSCOPED_SESSION_CHAT_RESTORE=false

# ─── Paths (inside container; must match volume mount targets) ────────────────
SESSION_DIR=session
LOGS_DIR=logs
UPLOADS_DIR=uploads

# ─── Qwen API URLs ────────────────────────────────────────────────────────────
QWEN_BASE_URL=https://chat.qwen.ai
# CHAT_API_URL=
# CREATE_CHAT_URL=
# CHAT_PAGE_URL=
# TASK_STATUS_URL=
# STS_TOKEN_API_URL=
# AUTH_SIGNIN_URL=
# OSS_SDK_URL=

# ─── Timeouts (ms) ────────────────────────────────────────────────────────────
# PAGE_TIMEOUT=120000
# AUTH_TIMEOUT=120000
# NAVIGATION_TIMEOUT=60000
# RETRY_DELAY=2000
# STREAMING_CHUNK_DELAY=20

# ─── Limits ───────────────────────────────────────────────────────────────────
# PAGE_POOL_SIZE=3
# MAX_FILE_SIZE=10485760
# MAX_HISTORY_LENGTH=100
# MAX_RETRY_COUNT=3
# TASK_POLL_MAX_ATTEMPTS=90
# TASK_POLL_INTERVAL=2000

# ─── Browser ──────────────────────────────────────────────────────────────────
# CHROME_PATH=/usr/bin/chromium
# VIEWPORT_WIDTH=1920
# VIEWPORT_HEIGHT=1080
# USER_AGENT=

# ─── Logging ──────────────────────────────────────────────────────────────────
# LOG_LEVEL=info
# LOG_MAX_SIZE=5242880
# LOG_MAX_FILES=5

# ─── Optional: DashScope direct image API (not required for Qwen Chat images) ─
# DASHSCOPE_API_KEY=
